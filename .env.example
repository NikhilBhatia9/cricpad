# Supabase (required for player stats & match history)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Firebase Realtime DB (required for live multi-device scoring)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Google Analytics 4 (optional — tracks devices, sessions, countries)
# Create a property at https://analytics.google.com → get Measurement ID (G-XXXXXXXXXX)
# Add as a GitHub Actions secret: Settings → Secrets → Actions → New secret → VITE_GA_ID
VITE_GA_ID=G-XXXXXXXXXX
